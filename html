            font-weight: 700;
        }

        .highlight-box {
            background: rgba(0, 229, 255, 0.03);
            border: 1px dashed var(--blue-law);
            padding: 15px;
            border-radius: 8px;
            margin: 20px 0;
        }

        .highlight-box h4 {
            font-family: 'Mitr', sans-serif;
            color: var(--blue-law);
            font-size: 1rem;
            margin-bottom: 10px;
        }

        .highlight-box ul {
            list-style-type: none;
        }

        .highlight-box li {
            font-size: 0.85rem;
            margin-bottom: 10px;
            padding-left: 20px;
