<script>
    let synth = window.speechSynthesis;
    let utterance = null;
    let isPaused = false;

    function speakText() {
        // ถ้ากำลัง Pause อยู่ให้กดเล่นต่อได้เลย
        if (synth.speaking && isPaused) {
            synth.resume();
            isPaused = false;
            document.getElementById('btn-play').innerText = "▶️ กำลังอ่าน...";
            return;
        }

        // ถ้ากำลังพูดอยู่แล้วกดซ้ำ ให้ข้ามไป
        if (synth.speaking) return;

        // รวบรวมข้อความทั้งหมดในเพจมาประมวลผลคำอ่าน
        let textToSpeak = "หัวข้อเว็บไซต์: ถ้าเกิดไม่แฉสังคมจะดีขึ้น พื้นที่หยุดยั้งความรุนแรงไซเบอร์ สะท้อนจิตวิทยาและอนาคตของครอบครัว ";
        textToSpeak += document.getElementById('t1').innerText + " ";
        
        let paragraphs = document.querySelectorAll('#main-content .section-title, #main-content .essay, #main-content .highlight-box li');
        paragraphs.forEach(p => {
            textToSpeak += p.innerText + " ";
        });

        utterance = new SpeechSynthesisUtterance(textToSpeak);
        
        // ฟังก์ชันค้นหาและดึงเสียง Google ภาษาไทยมาใช้งาน
        let voices = synth.getVoices();
        let thaiVoice = voices.find(voice => voice.lang === 'th-TH' && voice.name.includes('Google'));
        
        // ถ้าหาเสียงกูเกิลตรงๆ ไม่เจอ ให้เลือกเสียงภาษาไทยมาตรฐานแทน
        if (!thaiVoice) {
            thaiVoice = voices.find(voice => voice.lang === 'th-TH');
        }

        if (thaiVoice) {
            utterance.voice = thaiVoice;
        }

        // ปรับตั้งค่าความเร็วและโทนเสียงให้ฟังง่าย
        utterance.rate = 1.0; 
        utterance.pitch = 1.0;

        utterance.onend = function() {
            document.getElementById('btn-play').innerText = "▶️ กดฟังเสียงอ่าน";
            isPaused = false;
        };

        document.getElementById('btn-play').innerText = "▶️ กำลังอ่าน...";
        synth.speak(utterance);
    }

    function pauseText() {
        if (synth.speaking && !isPaused) {
            synth.pause();
            isPaused = true;
            document.getElementById('btn-play').innerText = "▶️ กดเพื่อฟังต่อ";
        }
    }

    function stopText() {
        if (synth.speaking || isPaused) {
            synth.cancel();
            isPaused = false;
            document.getElementById('btn-play').innerText = "▶️ กดฟังเสียงอ่าน";
        }
    }

    // โหลดรายชื่อเสียงเตรียมไว้สำหรับบราวเซอร์บางตัวที่โหลดช้า
    if (speechSynthesis.onvoiceschanged !== undefined) {
        speechSynthesis.onvoiceschanged = synth.getVoices;
    }
</script>

