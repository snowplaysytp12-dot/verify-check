            color: #fff;
        }

        .cyber-info p {
            font-size: 0.8rem;
            color: #ffecc2;
        }

        .cyber-phone {
            font-family: 'Chakra Petch', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--gold-warn);
            text-align: center;
            background: rgba(0,0,0,0.4);
            padding: 5px;
            border-radius: 6px;
            border: 1px solid rgba(255, 215, 0, 0.3);
        }

        .content-card {
            background-color: var(--panel-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px 15px;
            box-shadow: 0 15px 30px rgba(0,0,0,0.5);
            margin-bottom: 25px;
        }

        .section-title {
            font-family: 'Mitr', sans-serif;
            font-size: 1.3rem;
            color: #ffffff;
            margin-top: 25px;
            margin-bottom: 15px;
            border-bottom: 2px solid rgba(255,255,255,0.05);
            padding-bottom: 5px;
        }
        .section-title:first-of-type { margin-top: 0; }

        p.essay {
            font-size: 0.95rem;
            margin-bottom: 15px;
            text-align: justify;
            color: #e2daf8;
            line-height: 1.5;
        }

        p.essay strong {
