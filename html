            border-left: 4px solid var(--blue-law);
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 25px;
            border: 1px solid rgba(0, 229, 255, 0.2);
        }

        .explanation-banner h3 {
            font-family: 'Mitr', sans-serif;
            color: var(--blue-law);
            font-size: 1.1rem;
            margin-bottom: 5px;
        }

        .explanation-banner p {
            font-size: 0.85rem;
            color: #bfaee3;
            text-align: justify;
        }

        .cyber-banner {
            background: linear-gradient(90deg, #3a0e1c 0%, #1a050d 100%);
            border-left: 4px solid var(--gold-warn);
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 25px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            border: 1px solid rgba(255, 215, 0, 0.2);
