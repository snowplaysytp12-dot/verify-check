        /* โซนปุ่มกดอ่านด้วยเสียง */
        .audio-control-panel {
            background: #1b1635;
            border: 1px solid var(--blue-law);
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 25px;
            text-align: center;
            box-shadow: 0 0 15px rgba(0, 229, 255, 0.1);
        }

        .audio-control-panel p {
            font-size: 0.9rem;
            margin-bottom: 10px;
            color: #fff;
            font-family: 'Mitr', sans-serif;
        }

        .btn-audio {
            background: linear-gradient(135deg, #00d2ff 0%, #0076ff 100%);
            border: none;
            color: white;
            padding: 10px 20px;
            font-size: 0.95rem;
            font-family: 'Mitr', sans-serif;
            font-weight: 600;
            border-radius: 30px;
            cursor: pointer;
            margin: 5px;
            transition: all 0.2s ease;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }

        .btn-audio:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0, 229, 255, 0.4);
        }

        .btn-audio.stop {
            background: linear-gradient(135deg, #ff6b6b 0%, #ff3333 100%);
        }

        .btn-audio.pause {
            background: linear-gradient(135deg, #f3ca40 0%, #d4af37 100%);
            color: #110e22;
        }

        .explanation-banner {
