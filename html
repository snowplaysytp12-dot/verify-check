        .highlight-box li::before {
            content: '⚖️';
            position: absolute;
            left: 0;
            top: 0;
        }

        footer {
            text-align: center;
            padding: 20px 0;
            font-family: 'Chakra Petch', sans-serif;
            font-size: 0.75rem;
            color: var(--text-muted);
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            line-height: 1.4;
        }

        @media (min-width: 600px) {
            body { padding: 40px 20px; }
            header h1 { font-size: 2.3rem; }
